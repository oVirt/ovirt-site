%section#hp-hero
  / The banner is integrated as the soul of the Hero section
  .hero-banner-wrapper
    %img{:src => "/images/banners/banner.svg", :alt => "oVirt Logo"}

  .container
    .row
      .col-md-8.col-md-offset-2.text-center
        %h1
          The Engine of
          %span Open
          Virtualization.
        %p
          Scalable. Secure. 100% Community-Driven. Manage your entire enterprise infrastructure from a single, powerful interface.
        .hero-actions
          %a.btn.btn-lg{:href => "/download/", :style => "background: #0088CE; color: #fff; padding: 18px 45px; font-weight: 700; border-radius: 50px; margin-right: 15px; border: none; transition: 0.3s;"}
            Deploy oVirt 4.5
          %a.btn.btn-lg{:href => "/community/", :style => "border: 2px solid #0088CE; color: #0088CE; padding: 16px 45px; font-weight: 700; border-radius: 50px; background: transparent;"}
            Join the community

%section#community-pulse
  .container
    .row
      .col-md-3
        .pulse-card
          .status-dot
          %span Community activity
          %h3 User forums
          %p Help others, solve complex architecture hurdles, and share your setup.
          %a{:href => "https://lists.ovirt.org/"} Start a discussion →

      .col-md-3
        .pulse-card
          .status-dot
          %span Real-time chat
          %h3 IRC & Matrix
          %p Connect directly with developers and power users on OFTC IRC (#ovirt) or via Matrix.
          %a{:href => "/community/about/contact.html"} Get in touch →

      .col-md-3
        .pulse-card
          .status-dot
          %span Project health
          %h3 Recent releases
          %p 4.5.7 is live. See what the community built for your enterprise.
          %a{:href => "/release/4.5.7/"} View release notes →

      .col-md-3
        .pulse-card
          .status-dot
          %span Get involved
          %h3 Developer hub
          %p Contribute to the project. We are open for pull requests.
          %a{:href => "/develop/"} Build with us →

